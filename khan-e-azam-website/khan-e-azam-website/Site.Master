	<script>
		jQuery(document).ready(function(){
			if (typeof dzSettings !== 'undefined' && typeof dzSettingsOptions !== 'undefined') {
				dzSettingsOptions.themeFullColor_value = 'color_2';
				new dzSettings(dzSettingsOptions);
			}
		});
		// Custom cursor tracking — bypasses minified JS variable conflicts
		(function() {
			var cur = document.getElementById('cursor');
			var curBorder = document.getElementById('cursor-border');
			if (!cur || !curBorder) return;
			var mx = 0, my = 0, bx = 0, by = 0, revealed = false;
			document.addEventListener('mousemove', function(e) {
				mx = e.clientX;
				my = e.clientY;
				cur.style.transform = 'translate(' + mx + 'px, ' + my + 'px)';
				if (!revealed) {
					cur.style.opacity = '1';
					curBorder.style.opacity = '1';
					revealed = true;
				}
			});
			(function rafLoop() {
				bx += (mx - bx) * 0.15;
				by += (my - by) * 0.15;
				curBorder.style.transform = 'translate(' + bx + 'px, ' + by + 'px)';
				requestAnimationFrame(rafLoop);
			})();
		})();
	</script>
	<script>
		window.addEventListener('load', function () {
			var loader = document.getElementById('dzPageLoader');
			if (loader) { loader.classList.add('loaded'); }
		});

		// Fires after every UpdatePanel async postback
		function pageLoad() {
			var loader = document.getElementById('dzPageLoader');
			if (loader) { loader.classList.add('loaded'); }
			// Re-run page-specific post-update logic (e.g. order tracker)
			if (typeof window.keaPostUpdate === 'function') { window.keaPostUpdate(); }
			// Re-bind nav handlers — UpdatePanel replaces DOM so jQuery handlers are lost
			if (typeof jQuery !== 'undefined') {
				jQuery('.togglebtn').off('click').on('click.kea', function () {
					var $btn = jQuery(this);
					$btn.toggleClass('open');
					jQuery('.header-nav').toggleClass('open');
					jQuery('.menu-backdrop').toggleClass('show');
					$btn.find('.bar1').toggleClass('rotate1');
					$btn.find('.bar2').toggleClass('opacity0');
					$btn.find('.bar3').toggleClass('rotate2');
				});
				jQuery('.menu-backdrop').off('click.kea').on('click.kea', function () {
					jQuery(this).removeClass('show');
					jQuery('.header-nav').removeClass('open');
					jQuery('.togglebtn').removeClass('open');
					jQuery('.bar1').removeClass('rotate1');
					jQuery('.bar2').removeClass('opacity0');
					jQuery('.bar3').removeClass('rotate2');
					jQuery('#drawer1,#drawer2').removeClass('drawer-show');
					jQuery('.contact-sidebar').removeClass('open');
					jQuery('.filter-category-sidebar').removeClass('drawer-show');
					jQuery('body').css({ overflow: 'auto' });
				});
				jQuery('.menu-btn').off('click.kea').on('click.kea', function () {
					jQuery('.contact-sidebar').toggleClass('open');
					jQuery('.menu-backdrop').toggleClass('show');
				});
				DzCart.badge();
			}
		}
	</script>
	<script>
	/* ===== Khan-E-Azam Cart (localStorage) ===== */
	var DzCartCheckoutUrl = '<%= ResolveUrl("~/Pages/Checkout.aspx") %>';
	var DzCart = {
		KEY: 'kea_cart_v3',
		get: function () { try { return JSON.parse(localStorage.getItem(this.KEY)) || []; } catch(e){ return []; } },
		save: function (items) { localStorage.setItem(this.KEY, JSON.stringify(items)); this.badge(); },
		add: function (id, name, priceStr, image) {
			var items = this.get();
			var numMatch = (priceStr + '').replace(/,/g, '').match(/\d+(\.\d+)?/);
			var price = numMatch ? parseFloat(numMatch[0]) : 0;
			var found = false;
			for (var i = 0; i < items.length; i++) { if (items[i].id === id) { items[i].qty++; found = true; break; } }
			if (!found) items.push({ id: id, name: name, price: price, priceStr: priceStr, image: image, qty: 1 });
			this.save(items);
			this.toast('✓ ' + name + ' added to cart!');
		},
		remove: function (id) { this.save(this.get().filter(function(x){ return x.id !== id; })); },
		setQty: function (id, qty) {
			var items = this.get();
			for (var i = 0; i < items.length; i++) {
				if (items[i].id === id) { if (qty < 1) items.splice(i,1); else items[i].qty = qty; break; }
			}
			this.save(items);
		},
		count: function () { return this.get().reduce(function(s,x){ return s+x.qty; },0); },
		total: function () { return this.get().reduce(function(s,x){ return s+x.price*x.qty; },0); },
		clear: function () { this.save([]); },
		badge: function () {
			var b = document.getElementById('dz-cart-badge');
			var co = document.getElementById('dz-checkout-fab');
			var n = this.count();
			if (b) { b.textContent = n; b.style.display = n > 0 ? 'flex' : 'none'; }
			if (co) { if (n > 0) { co.classList.remove('hidden'); co.href = DzCartCheckoutUrl; } else { co.classList.add('hidden'); } }
		},
		toast: function (msg) {
			var el = document.getElementById('dz-toast');
			if (!el) return;
			el.textContent = msg;
			el.style.opacity = '1'; el.style.transform = 'translateY(0)';
			clearTimeout(el._t);
			el._t = setTimeout(function(){ el.style.opacity='0'; el.style.transform='translateY(16px)'; }, 2500);
		}
	};
	document.addEventListener('DOMContentLoaded', function(){ DzCart.badge(); });
	document.addEventListener('click', function(e){
		var btn = e.target.closest ? e.target.closest('.dz-cart-add') : null;
		if (!btn) return;
		e.preventDefault(); e.stopPropagation();
		DzCart.add(btn.dataset.cartId, btn.dataset.name, btn.dataset.price, btn.dataset.image || '');
	});
	</script>
    </form>
</body>
</html>
