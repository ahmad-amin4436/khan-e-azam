	<style>
		/* Page loader */
		@keyframes dz-spin { to { transform: rotate(360deg); } }
		.dz-spinner { width:44px; height:44px; border-radius:50%; border:4px solid rgba(255,255,255,0.25); border-top-color:#fff; animation:dz-spin .65s linear infinite; margin-top:18px; }
		#dzPageLoader { transition:opacity .35s ease, visibility .35s ease; }
		#dzPageLoader.loaded { opacity:0; visibility:hidden; pointer-events:none; }
		/* FABs */
		.dz-fab-stack { position:fixed; bottom:24px; right:24px; z-index:99998; display:flex; flex-direction:column-reverse; align-items:center; gap:12px; }
		.dz-fab { width:54px; height:54px; border-radius:50%; display:flex; align-items:center; justify-content:center; text-decoration:none; box-shadow:0 4px 18px rgba(0,0,0,.25); transition:transform .2s, box-shadow .2s;  }
		.dz-fab:hover { transform:scale(1.1); box-shadow:0 6px 24px rgba(0,0,0,.35); }
		.dz-fab-wa  { background:#25D366; box-shadow:0 4px 18px rgba(37,211,102,.45); }
		.dz-fab-cart { background:var(--primary); position:relative; }
		.dz-fab-checkout { background:#222; }
		#dz-cart-badge { position:absolute; top:-4px; right:-4px; background:#e74c3c; color:#fff; font-size:11px; font-weight:700; min-width:20px; height:20px; border-radius:10px; display:none; align-items:center; justify-content:center; padding:0 4px; }
		#dz-toast { position:fixed; bottom:110px; right:24px; background:rgba(30,30,30,.92); color:#fff; padding:10px 18px; border-radius:8px; font-size:13px; z-index:999999; opacity:0; transform:translateY(16px); transition:opacity .3s, transform .3s; pointer-events:none; max-width:260px; }
		#cursor, #cursor-border { opacity:0; transition:opacity .2s; }
	</style>
</head>
